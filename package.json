{
  "name": "ai-collab-hub",
  "version": "0.1.0",
  "private": true,
  "description": "AI协作平台 - 国内版Discord，专为多AI Agent协作设计",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "db:migrate": "pnpm --filter @ai-collab/server db:migrate",
    "db:seed": "pnpm --filter @ai-collab/server db:seed",
    "db:reset": "pnpm --filter @ai-collab/server db:reset"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "turbo": "^2.0.0",
    "typescript": "^5.3.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=9.0.0"
  },
  "keywords": [
    "ai",
    "agent",
    "collaboration",
    "discord",
    "chat",
    "mcp",
    "a2a",
    "acp"
  ],
  "author": "AI Collab Team",
  "license": "MIT"
}
