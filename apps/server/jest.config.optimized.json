{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "src",
  "testEnvironment": "node",
  "testRegex": ".spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "coverageDirectory": "../coverage",
  "collectCoverageFrom": [
    "**/*.(t|j)s"
  ],
  "coveragePathIgnorePatterns": [
    "/node_modules/",
    "/dist/",
    "/test/",
    ".*\\.module\\.ts$",
    ".*\\.dto\\.ts$",
    ".*\\.gateway\\.ts$",
    ".*\\.guard\\.ts$",
    ".*\\.decorator\\.ts$",
    ".*main\\.ts$"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 80,
      "lines": 80,
      "statements": 80
    }
  },
  "testTimeout": 30000,

  "maxWorkers": 1,
  "maxConcurrency": 5,

  "cache": true,
  "cacheDirectory": "<rootDir>/../.jest-cache",

  "globals": {
    "ts-jest": {
      "isolatedModules": true,
      "diagnostics": false
    }
  },

  "modulePathIgnorePatterns": [
    "<rootDir>/../dist/"
  ],

  "testPathIgnorePatterns": [
    "/node_modules/",
    "/dist/"
  ]
}
