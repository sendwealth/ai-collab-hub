// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Agent
// ============================================

model Agent {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  publicKey     String        @map("public_key")
  apiKey        String        @unique @default(uuid()) @map("api_key")

  // SQLite不支持Json，使用String存储JSON字符串
  capabilities  String?       // JSON string
  endpoint      String?       // JSON string
  metadata      String?       // JSON string

  status        String        @default("idle") // idle, busy, offline
  trustScore    Int           @default(0) @map("trust_score")

  lastSeen      DateTime?     @map("last_seen")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  createdTasks  Task[]        @relation("CreatedTasks")
  assignedTasks Task[]        @relation("AssignedTasks")
  bids          Bid[]
  files         File[]
  ownedTeams    Team[]        @relation("TeamOwner")
  teamMemberships TeamMember[] @relation("TeamMember")

  @@map("agents")
}

// ============================================
// Task
// ============================================

model Task {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        String      @default("independent") // independent, collaborative, workflow
  category    String?

  // SQLite不支持Json，使用String存储JSON字符串
  requirements String?    // JSON string
  reward       String?    // JSON string
  result       String?    // JSON string
  deadline     DateTime?

  status      String      @default("open") // open, assigned, reviewing, completed, cancelled

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  createdById String?     @map("created_by_id")
  assigneeId  String?     @map("assignee_id")

  creator     Agent?      @relation("CreatedTasks", fields: [createdById], references: [id])
  assignee    Agent?      @relation("AssignedTasks", fields: [assigneeId], references: [id])

  bids        Bid[]
  files       File[]

  // 子任务关系
  parentRelations  TaskRelation[] @relation("ChildTasks")
  childRelations   TaskRelation[] @relation("ParentTasks")

  @@map("tasks")
}

// ============================================
// TaskRelation (子任务关系)
// ============================================

model TaskRelation {
  id        String   @id @default(uuid())
  parentId  String   @map("parent_id")
  childId   String   @map("child_id")
  order     Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  parent    Task     @relation("ParentTasks", fields: [parentId], references: [id], onDelete: Cascade)
  child     Task     @relation("ChildTasks", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@map("task_relations")
}

// ============================================
// Bid
// ============================================

model Bid {
  id            String    @id @default(uuid())
  proposal      String
  estimatedTime Int?      @map("estimated_time")
  estimatedCost Float?    @map("estimated_cost")

  status        String    @default("pending") // pending, accepted, rejected

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  taskId        String    @map("task_id")
  agentId       String    @map("agent_id")

  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([agentId])
  @@map("bids")
}

// ============================================
// Team
// ============================================

model Team {
  id          String       @id @default(uuid())
  name        String
  description String?

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  ownerId     String       @map("owner_id")
  owner       Agent        @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]

  @@index([ownerId])
  @@map("teams")
}

// ============================================
// TeamMember
// ============================================

model TeamMember {
  id        String   @id @default(uuid())
  role      String   @default("member") // owner, admin, member

  joinedAt  DateTime @default(now()) @map("joined_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  teamId    String   @map("team_id")
  agentId   String   @map("agent_id")

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent     Agent    @relation("TeamMember", fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
  @@index([teamId])
  @@index([agentId])
  @@map("team_members")
}

// ============================================
// File
// ============================================

model File {
  id          String    @id @default(uuid())
  filename    String
  path        String
  size        Int
  mimeType    String    @map("mime_type")
  version     Int       @default(1)
  
  // Relations
  taskId      String?   @map("task_id")
  agentId     String     @map("agent_id")
  parentId    String?    @map("parent_id")
  
  task        Task?      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent       Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  parent      File?      @relation("FileHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    File[]     @relation("FileHierarchy")
  
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  
  @@index([taskId])
  @@index([agentId])
  @@index([parentId])
  @@map("files")
}

// ============================================
// Notification
// ============================================

model Notification {
  id          String    @id @default(uuid())
  agentId     String    @map("agent_id")
  type        String    // e.g., "task_assigned", "task_completed", "bid_accepted"
  title       String
  message     String
  data        String?   // JSON string for additional data
  read        Boolean   @default(false) @map("is_read")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  
  @@index([agentId])
  @@index([read])
  @@map("notifications")
}

// ============================================
// Credit
// ============================================

model Credit {
  id            String             @id @default(uuid())
  agentId       String             @unique @map("agent_id")
  balance       Int                @default(0)
  frozenBalance Int                @default(0) @map("frozen_balance")
  totalEarned   Int                @default(0) @map("total_earned")
  totalSpent    Int                @default(0) @map("total_spent")
  
  createdAt     DateTime           @default(now()) @map("created_at")
  updatedAt     DateTime           @updatedAt @map("updated_at")
  
  // Relations
  transactions  CreditTransaction[]
  
  @@map("credits")
}

// ============================================
// CreditTransaction
// ============================================

model CreditTransaction {
  id          String    @id @default(uuid())
  agentId     String    @map("agent_id")
  type        String    // deposit, withdraw, transfer, earn, spend
  amount      Int       // positive for income, negative for expense
  balance     Int       // balance after transaction
  description String?
  metadata    String?   // JSON string for additional data (e.g., fromAgentId, toAgentId)
  taskId      String?   @map("task_id")
  
  createdAt   DateTime  @default(now()) @map("created_at")
  
  // Relations
  credit      Credit    @relation(fields: [agentId], references: [agentId], onDelete: Cascade)
  
  @@index([agentId])
  @@index([type])
  @@index([createdAt])
  @@map("credit_transactions")
}

// ============================================
// Phase 3: AI Recommendation System Models
// ============================================

// Agent Capabilities Vector
model AgentCapability {
  id            String   @id @default(uuid())
  agentId       String   @unique @map("agent_id")
  
  // Skill vectors (normalized scores 0-100)
  coding        Int      @default(0)
  writing       Int      @default(0)
  analysis      Int      @default(0)
  design        Int      @default(0)
  testing       Int      @default(0)
  devops        Int      @default(0)
  dataScience   Int      @default(0) @map("data_science")
  machineLearning Int    @default(0) @map("machine_learning")
  projectMgmt   Int      @default(0) @map("project_mgmt")
  
  // Specialized skills (JSON array)
  specialized   String?  // JSON string array
  
  // Last updated
  updatedAt     DateTime @updatedAt @map("updated_at")
  
  @@index([agentId])
  @@map("agent_capabilities")
}

// Agent Performance Metrics
model AgentPerformance {
  id                String   @id @default(uuid())
  agentId           String   @map("agent_id")
  
  // Performance metrics
  tasksCompleted    Int      @default(0) @map("tasks_completed")
  tasksFailed       Int      @default(0) @map("tasks_failed")
  totalBids         Int      @default(0) @map("total_bids")
  acceptedBids      Int      @default(0) @map("accepted_bids")
  
  // Quality metrics
  avgRating         Float    @default(0) @map("avg_rating")
  onTimeDelivery    Float    @default(0) @map("on_time_delivery") // percentage
  
  // Speed metrics
  avgResponseTime   Int      @default(0) @map("avg_response_time") // minutes
  avgCompletionTime Int      @default(0) @map("avg_completion_time") // hours
  
  // Earnings
  totalEarned       Int      @default(0) @map("total_earned")
  avgTaskValue      Float    @default(0) @map("avg_task_value")
  
  // Period
  periodStart       DateTime @map("period_start")
  periodEnd         DateTime @map("period_end")
  
  updatedAt         DateTime @updatedAt @map("updated_at")
  
  @@index([agentId])
  @@index([periodStart])
  @@map("agent_performance")
}

// Recommendation Log
model RecommendationLog {
  id                String   @id @default(uuid())
  type              String   // "agent" or "task"
  
  // Input
  inputId           String   @map("input_id") // taskId or agentId
  inputFeatures     String   // JSON string
  
  // Output
  recommendations   String   // JSON array of recommended IDs with scores
  
  // Context
  context           String?  // JSON string (user preferences, filters, etc.)
  
  // Performance tracking
  clicked           Boolean  @default(false)
  accepted          Boolean  @default(false)
  
  createdAt         DateTime @default(now()) @map("created_at")
  
  @@index([type])
  @@index([inputId])
  @@index([createdAt])
  @@map("recommendation_logs")
}

// Price History
model PriceHistory {
  id              String   @id @default(uuid())
  category        String
  
  // Task details
  taskId          String?  @map("task_id")
  taskType        String?  @map("task_type")
  difficulty      String?  // easy, medium, hard
  
  // Price data
  suggestedPrice  Int      @map("suggested_price")
  finalPrice      Int      @map("final_price")
  
  // Market data
  avgMarketPrice  Int      @map("avg_market_price")
  supplyLevel     String   @map("supply_level") // low, medium, high
  demandLevel     String   @map("demand_level") // low, medium, high
  
  createdAt       DateTime @default(now()) @map("created_at")
  
  @@index([category])
  @@index([taskId])
  @@index([createdAt])
  @@map("price_history")
}

// Market Trends
model MarketTrend {
  id              String   @id @default(uuid())
  category        String

  // Statistics
  totalTasks      Int      @default(0) @map("total_tasks")
  avgPrice        Int      @default(0) @map("avg_price")
  avgCompletionTime Int    @default(0) @map("avg_completion_time")

  // Supply/Demand
  availableAgents Int      @default(0) @map("available_agents")
  openTasks       Int      @default(0) @map("open_tasks")
  ratio           Float    @default(0) // supply/demand ratio

  // Period
  periodStart     DateTime @map("period_start")
  periodEnd       DateTime @map("period_end")

  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([category])
  @@index([periodStart])
  @@map("market_trends")
}

// ============================================
// Phase 4: Workflow Engine Models
// ============================================

// Workflow Template
model WorkflowTemplate {
  id          String   @id @default(uuid())
  name        String
  description String?
  category    String   // data-processing, content-creation, code-review, analysis
  version     String   @default("1.0.0")

  // Workflow definition (JSON)
  definition  String   // JSON string with nodes and edges

  // Metadata
  tags        String?  // JSON string array
  author      String?
  isActive    Boolean  @default(true)

  // Statistics
  usageCount  Int      @default(0) @map("usage_count")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  // Relations
  instances   WorkflowInstance[]

  @@index([category])
  @@index([isActive])
  @@map("workflow_templates")
}

// Workflow Instance
model WorkflowInstance {
  id           String   @id @default(uuid())

  // Relations
  templateId   String   @map("template_id")
  template     WorkflowTemplate @relation(fields: [templateId], references: [id])

  taskId       String?  @map("task_id")

  // Status
  status       String   @default("pending") // pending, running, paused, completed, failed, cancelled

  // Execution context
  context      String   // JSON string with workflow variables
  currentNode  String?  @map("current_node") // Current executing node ID

  // Timing
  startedAt    DateTime? @map("started_at")
  completedAt  DateTime? @map("completed_at")

  // Error tracking
  errorMessage String?  @map("error_message")
  retryCount   Int      @default(0) @map("retry_count")

  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  nodeExecutions WorkflowNodeExecution[]

  @@index([templateId])
  @@index([taskId])
  @@index([status])
  @@map("workflow_instances")
}

// Workflow Node Execution
model WorkflowNodeExecution {
  id         String   @id @default(uuid())

  // Relations
  instanceId String   @map("instance_id")
  instance   WorkflowInstance @relation(fields: [instanceId], references: [id], onDelete: Cascade)

  // Node details
  nodeId     String   @map("node_id") // Node ID from workflow definition
  nodeType   String   @map("node_type") // start, end, task, condition, parallel, delay, loop

  // Execution status
  status     String   @default("pending") // pending, running, completed, failed, skipped

  // Input/Output
  input      String?  // JSON string
  output     String?  // JSON string

  // Error handling
  error      String?
  retryCount Int      @default(0) @map("retry_count")

  // Timing
  startedAt  DateTime? @map("started_at")
  completedAt DateTime? @map("completed_at")
  duration   Int?     // milliseconds

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([instanceId])
  @@index([nodeId])
  @@index([status])
  @@map("workflow_node_executions")
}

// Analytics Dashboard Data
model DashboardMetric {
  id          String   @id @default(uuid())
  type        String   // active_agents, tasks_completed, revenue, user_growth

  // Metric value
  value       Float
  change      Float?   // Percentage change from previous period
  trend       String?  // up, down, stable

  // Period
  period      String   // hour, day, week, month
  timestamp   DateTime @map("timestamp")

  // Metadata
  metadata    String?  // JSON string for additional data

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([type])
  @@index([period])
  @@index([timestamp])
  @@map("dashboard_metrics")
}

// Audit Log (for security and compliance)
model AuditLog {
  id          String   @id @default(uuid())

  // Who
  agentId     String?  @map("agent_id")
  userId      String?  @map("user_id") // For future human users

  // What
  action      String   // create, update, delete, execute, etc.
  resource    String   // agent, task, workflow, etc.
  resourceId  String?  @map("resource_id")

  // Details
  changes     String?  // JSON string with before/after values
  metadata    String?  // JSON string for additional context

  // Context
  ipAddress   String?  @map("ip_address")
  userAgent   String?  @map("user_agent")

  // Result
  success     Boolean  @default(true)
  errorMessage String? @map("error_message")

  createdAt   DateTime @default(now()) @map("created_at")

  @@index([agentId])
  @@index([action])
  @@index([resource])
  @@index([createdAt])
  @@map("audit_logs")
}
