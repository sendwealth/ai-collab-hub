// Prisma Schema for AI Collab Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// 用户和认证
// ============================================

model User {
  id            String    @id @default(uuid())
  username      String    @unique
  email         String    @unique
  passwordHash  String    @map("password_hash")
  type          UserType  @default(HUMAN)
  avatar        String?
  status        UserStatus @default(OFFLINE)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // 关系
  messages      Message[]
  channels      ChannelMember[]
  agents        Agent?
  tasks         Task[]      @relation("TaskCreator")
  assignedTasks Task[]      @relation("TaskAssignee")
  memories      Memory[]

  @@map("users")
}

enum UserType {
  HUMAN
  AGENT
}

enum UserStatus {
  ONLINE
  BUSY
  OFFLINE
}

// ============================================
// Agent
// ============================================

model Agent {
  id          String          @id @default(uuid())
  userId      String          @unique @map("user_id")
  name        String
  description String?
  capabilities Json           @default("{}")
  endpoint    String?
  metadata    Json            @default("{}")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  // 关系
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@map("agents")
}

// ============================================
// 频道和消息
// ============================================

model Channel {
  id          String        @id @default(uuid())
  name        String
  type        ChannelType
  description String?
  createdById String?       @map("created_by")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  // 关系
  members     ChannelMember[]
  messages    Message[]

  @@map("channels")
}

enum ChannelType {
  DM      // 私聊
  GROUP   // 群聊
  TASK    // 任务频道
}

model ChannelMember {
  channelId   String    @map("channel_id")
  userId      String    @map("user_id")
  role        MemberRole @default(MEMBER)
  joinedAt    DateTime  @default(now()) @map("joined_at")

  // 关系
  channel     Channel   @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([channelId, userId])
  @@map("channel_members")
}

enum MemberRole {
  OWNER
  ADMIN
  MEMBER
}

model Message {
  id          String        @id @default(uuid())
  channelId   String        @map("channel_id")
  senderId    String        @map("sender_id")
  parentId    String?       @map("parent_id")
  content     String        @db.Text
  type        MessageType   @default(TEXT)
  metadata    Json          @default("{}")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")
  deletedAt   DateTime?     @map("deleted_at")

  // 关系
  channel     Channel       @relation(fields: [channelId], references: [id], onDelete: Cascade)
  sender      User          @relation(fields: [senderId], references: [id], onDelete: Cascade)
  reactions   Reaction[]

  @@index([channelId, createdAt(sort: Desc)])
  @@map("messages")
}

enum MessageType {
  TEXT
  FILE
  IMAGE
  SYSTEM
  TASK
}

model Reaction {
  id          String      @id @default(uuid())
  messageId   String      @map("message_id")
  userId      String      @map("user_id")
  emoji       String
  createdAt   DateTime    @default(now()) @map("created_at")

  // 关系
  message     Message     @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@map("reactions")
}

// ============================================
// 任务
// ============================================

model Task {
  id          String      @id @default(uuid())
  title       String
  description String?     @db.Text
  channelId   String?     @map("channel_id")
  creatorId   String      @map("creator_id")
  assigneeId  String?     @map("assignee_id")
  status      TaskStatus  @default(PENDING)
  priority    TaskPriority @default(MEDIUM)
  result      Json?
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  completedAt DateTime?   @map("completed_at")

  // 关系
  creator     User        @relation("TaskCreator", fields: [creatorId], references: [id])
  assignee    User?       @relation("TaskAssignee", fields: [assigneeId], references: [id])
  agent       Agent?      @relation(fields: [assigneeId], references: [userId])
  dependencies TaskDependency[] @relation("TaskDepends")
  dependents  TaskDependency[] @relation("TaskDependent")

  @@index([assigneeId, status])
  @@map("tasks")
}

enum TaskStatus {
  PENDING
  ASSIGNED
  RUNNING
  COMPLETED
  FAILED
  CANCELLED
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

model TaskDependency {
  id            String    @id @default(uuid())
  taskId        String    @map("task_id")
  dependsOnId   String    @map("depends_on_id")
  type          DependencyType @default(HARD)
  createdAt     DateTime  @default(now()) @map("created_at")

  // 关系
  task          Task      @relation("TaskDepends", fields: [taskId], references: [id], onDelete: Cascade)
  dependsOn     Task      @relation("TaskDependent", fields: [dependsOnId], references: [id], onDelete: Cascade)

  @@unique([taskId, dependsOnId])
  @@map("task_dependencies")
}

enum DependencyType {
  HARD    // 必须完成
  SOFT    // 软依赖
}

// ============================================
// 记忆
// ============================================

model Memory {
  id          String      @id @default(uuid())
  agentId     String      @map("agent_id")
  type        MemoryType
  content     String      @db.Text
  embedding   Float[]     // 向量嵌入
  metadata    Json        @default("{}")
  createdAt   DateTime    @default(now()) @map("created_at")
  expiresAt   DateTime?   @map("expires_at")

  // 关系
  user        User        @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, type])
  @@map("memories")
}

enum MemoryType {
  SHORT   // 短期记忆
  LONG    // 长期记忆
  SHARED  // 共享记忆
}

// ============================================
// 会话和Token
// ============================================

model Session {
  id          String    @id @default(uuid())
  userId      String    @map("user_id")
  token       String    @unique
  userAgent   String?   @map("user_agent")
  ipAddress   String?   @map("ip_address")
  expiresAt   DateTime  @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@index([userId])
  @@map("sessions")
}
