// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// Agent
// ============================================

model Agent {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  publicKey     String        @map("public_key")
  apiKey        String        @unique @default(uuid()) @map("api_key")

  // SQLite不支持Json，使用String存储JSON字符串
  capabilities  String?       // JSON string
  endpoint      String?       // JSON string
  metadata      String?       // JSON string

  status        String        @default("idle") // idle, busy, offline
  trustScore    Int           @default(0) @map("trust_score")

  lastSeen      DateTime?     @map("last_seen")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")

  // Relations
  createdTasks  Task[]        @relation("CreatedTasks")
  assignedTasks Task[]        @relation("AssignedTasks")
  bids          Bid[]
  files         File[]
  ownedTeams    Team[]        @relation("TeamOwner")
  teamMemberships TeamMember[] @relation("TeamMember")

  @@map("agents")
}

// ============================================
// Task
// ============================================

model Task {
  id          String      @id @default(uuid())
  title       String
  description String?
  type        String      @default("independent") // independent, collaborative, workflow
  category    String?

  // SQLite不支持Json，使用String存储JSON字符串
  requirements String?    // JSON string
  reward       String?    // JSON string
  result       String?    // JSON string
  deadline     DateTime?

  status      String      @default("open") // open, assigned, reviewing, completed, cancelled

  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")

  // Relations
  createdById String?     @map("created_by_id")
  assigneeId  String?     @map("assignee_id")

  creator     Agent?      @relation("CreatedTasks", fields: [createdById], references: [id])
  assignee    Agent?      @relation("AssignedTasks", fields: [assigneeId], references: [id])

  bids        Bid[]
  files       File[]

  // 子任务关系
  parentRelations  TaskRelation[] @relation("ChildTasks")
  childRelations   TaskRelation[] @relation("ParentTasks")

  @@map("tasks")
}

// ============================================
// TaskRelation (子任务关系)
// ============================================

model TaskRelation {
  id        String   @id @default(uuid())
  parentId  String   @map("parent_id")
  childId   String   @map("child_id")
  order     Int      @default(0)

  createdAt DateTime @default(now()) @map("created_at")

  // Relations
  parent    Task     @relation("ParentTasks", fields: [parentId], references: [id], onDelete: Cascade)
  child     Task     @relation("ChildTasks", fields: [childId], references: [id], onDelete: Cascade)

  @@unique([parentId, childId])
  @@index([parentId])
  @@index([childId])
  @@map("task_relations")
}

// ============================================
// Bid
// ============================================

model Bid {
  id            String    @id @default(uuid())
  proposal      String
  estimatedTime Int?      @map("estimated_time")
  estimatedCost Float?    @map("estimated_cost")

  status        String    @default("pending") // pending, accepted, rejected

  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")

  // Relations
  taskId        String    @map("task_id")
  agentId       String    @map("agent_id")

  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent         Agent     @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([agentId])
  @@map("bids")
}

// ============================================
// Team
// ============================================

model Team {
  id          String       @id @default(uuid())
  name        String
  description String?

  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  // Relations
  ownerId     String       @map("owner_id")
  owner       Agent        @relation("TeamOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members     TeamMember[]

  @@index([ownerId])
  @@map("teams")
}

// ============================================
// TeamMember
// ============================================

model TeamMember {
  id        String   @id @default(uuid())
  role      String   @default("member") // owner, admin, member

  joinedAt  DateTime @default(now()) @map("joined_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Relations
  teamId    String   @map("team_id")
  agentId   String   @map("agent_id")

  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  agent     Agent    @relation("TeamMember", fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([teamId, agentId])
  @@index([teamId])
  @@index([agentId])
  @@map("team_members")
}

// ============================================
// File
// ============================================

model File {
  id          String    @id @default(uuid())
  filename    String
  path        String
  size        Int
  mimeType    String    @map("mime_type")
  version     Int       @default(1)
  
  // Relations
  taskId      String?   @map("task_id")
  agentId     String     @map("agent_id")
  parentId    String?    @map("parent_id")
  
  task        Task?      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent       Agent      @relation(fields: [agentId], references: [id], onDelete: Cascade)
  parent      File?      @relation("FileHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children    File[]     @relation("FileHierarchy")
  
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")
  
  @@index([taskId])
  @@index([agentId])
  @@index([parentId])
  @@map("files")
}
