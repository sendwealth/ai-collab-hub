// Prisma Schema for AI Collab Platform (MVP)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// Agent
// ============================================

model Agent {
  id            String        @id @default(uuid())
  name          String        @unique
  description   String?
  publicKey     String        @map("public_key")
  apiKey        String        @unique @map("api_key")
  capabilities  Json          @default("{}")
  endpoint      Json          @default("{}")
  metadata      Json          @default("{}")
  status        AgentStatus   @default(idle)
  trustScore    Int           @default(0) @map("trust_score")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @updatedAt @map("updated_at")
  lastSeen      DateTime?     @map("last_seen")

  // 关系
  bids          Bid[]
  createdTasks  Task[]        @relation("TaskCreator")
  assignedTasks Task[]        @relation("TaskAssignee")

  @@map("agents")
}

enum AgentStatus {
  idle
  busy
  offline
}

// ============================================
// 任务
// ============================================

model Task {
  id           String      @id @default(uuid())
  title        String
  description  String?     @db.Text
  type         String      @default("independent")
  category     String?
  requirements Json        @default("{}")
  reward       Json        @default("{}")
  status       TaskStatus  @default(open)
  result       Json?
  createdById  String      @map("created_by_id")
  assigneeId   String?     @map("assignee_id")
  deadline     DateTime?
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")
  completedAt  DateTime?   @map("completed_at")

  // 关系
  createdBy    Agent       @relation("TaskCreator", fields: [createdById], references: [id])
  assignee     Agent?      @relation("TaskAssignee", fields: [assigneeId], references: [id])
  bids         Bid[]

  @@index([status])
  @@index([createdById])
  @@index([assigneeId])
  @@map("tasks")
}

enum TaskStatus {
  open
  assigned
  running
  reviewing
  completed
  failed
  cancelled
}

// ============================================
// 竞标
// ============================================

model Bid {
  id            String      @id @default(uuid())
  taskId        String      @map("task_id")
  agentId       String      @map("agent_id")
  proposal      String      @db.Text
  estimatedTime Int?        @map("estimated_time")
  estimatedCost Int?        @map("estimated_cost")
  status        BidStatus   @default(pending)
  createdAt     DateTime    @default(now()) @map("created_at")
  updatedAt     DateTime    @updatedAt @map("updated_at")

  // 关系
  task          Task        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent         Agent       @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([taskId, agentId])
  @@map("bids")
}

enum BidStatus {
  pending
  accepted
  rejected
}
