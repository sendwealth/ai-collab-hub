# Environment Variables for AI Collab Hub - OAuth Configuration Template
# Generated: 2026-03-16
# 
# Instructions:
# 1. Copy this file to .env in the same directory
# 2. Replace placeholder values with your actual credentials
# 3. Never commit .env file to version control

# ============================================
# Database Configuration
# ============================================
DATABASE_URL="postgresql://aicollab:aicollab123@localhost:5433/aicollab?schema=public"

# ============================================
# Server Configuration
# ============================================
PORT=3000
NODE_ENV=development

# ============================================
# Redis Cache
# ============================================
REDIS_URL="redis://localhost:6379"

# ============================================
# Performance Monitoring
# ============================================
SLOW_QUERY_THRESHOLD=100

# ============================================
# JWT Configuration
# ============================================
# IMPORTANT: Change these secrets in production!
JWT_SECRET="dev-secret-key-change-in-production-20260315"
JWT_REFRESH_SECRET="dev-refresh-secret-change-in-production-20260315"

# ============================================
# API Configuration
# ============================================
API_KEY_SALT="dev-salt-change-in-production-20260315"

# ============================================
# GitHub OAuth Configuration
# ============================================
# 1. Go to: https://github.com/settings/developers
# 2. Create new OAuth App
# 3. Set Authorization callback URL
# 4. Copy Client ID and Client Secret below

GITHUB_CLIENT_ID="your_github_client_id_here"
GITHUB_CLIENT_SECRET="your_github_client_secret_here"

# Development callback URL
GITHUB_CALLBACK_URL="http://localhost:3000/api/v1/auth/github/callback"

# Production callback URL (uncomment for production)
# GITHUB_CALLBACK_URL="https://api.your-domain.com/api/v1/auth/github/callback"

# ============================================
# Google OAuth Configuration
# ============================================
# 1. Go to: https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add authorized JavaScript origins and redirect URIs
# 4. Copy Client ID and Client Secret below

GOOGLE_CLIENT_ID="your_google_client_id_here"
GOOGLE_CLIENT_SECRET="your_google_client_secret_here"

# Development callback URL
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# Production callback URL (uncomment for production)
# GOOGLE_CALLBACK_URL="https://api.your-domain.com/api/v1/auth/google/callback"

# ============================================
# Frontend Configuration
# ============================================
# URL where users will be redirected after OAuth login
# Development
FRONTEND_URL="http://localhost:3001"

# Production (uncomment for production)
# FRONTEND_URL="https://your-domain.com"

# ============================================
# Production Security Checklist
# ============================================
# Before deploying to production, ensure:
# [ ] DATABASE_URL uses strong password
# [ ] JWT_SECRET is a strong random string (min 32 characters)
# [ ] JWT_REFRESH_SECRET is different from JWT_SECRET
# [ ] API_KEY_SALT is a strong random string
# [ ] OAuth callback URLs use HTTPS
# [ ] FRONTEND_URL uses HTTPS
# [ ] GitHub/Google OAuth apps configured for production domains
# [ ] All secrets stored securely (not in code)
# [ ] .env file is in .gitignore

# ============================================
# How to Generate Strong Secrets
# ============================================
# Use these commands to generate secure random strings:
#
# macOS/Linux:
# openssl rand -base64 32
#
# Node.js:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
#
# Online (for development only):
# https://www.uuidgenerator.net/
