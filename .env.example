# ========================================
# AI协作平台 - 环境变量配置
# ========================================

# 应用配置
NODE_ENV=development
PORT=3000
API_PREFIX=/api/v1

# 数据库配置
DATABASE_URL=postgresql://admin:secret@localhost:5432/ai_collab

# Redis配置
REDIS_URL=redis://localhost:6379
REDIS_PREFIX=ai-collab:

# JWT配置
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# 文件存储配置 (MinIO)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=secret123
MINIO_BUCKET=ai-collab

# 向量数据库配置 (Milvus)
MILVUS_HOST=localhost
MILVUS_PORT=19530
MILVUS_COLLECTION=ai_collab

# 消息队列配置 (RabbitMQ)
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_EXCHANGE=ai-collab

# 搜索引擎配置 (Elasticsearch)
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_INDEX=ai-collab

# WebSocket配置
WS_PORT=3001
WS_PATH=/ws

# LLM配置 (可选)
OPENAI_API_KEY=sk-xxx
OPENAI_MODEL=gpt-4
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_MODEL=deepseek-chat

# Agent协议配置
MCP_SERVER_PORT=4000
A2A_ENABLED=true
ACP_ENABLED=true

# 日志配置
LOG_LEVEL=debug
LOG_FORMAT=pretty

# 监控配置 (可选)
SENTRY_DSN=
PROMETHEUS_PORT=9090

# 安全配置
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# CORS配置
CORS_ORIGIN=http://localhost:8080
CORS_CREDENTIALS=true
